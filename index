<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>献立ノート</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#2f3e3a;
    --paper:#f1ead9;
    --paper-card:#faf5e8;
    --line:#cfc2a3;
    --accent:#a8432f;
    --accent-soft:#e3c8b8;
    --asa:#d8a13a;
    --hiru:#5c8a68;
    --yoru:#3d5a80;
    --muted:#8a7f68;
    --good:#5c8a68;
    --ok:#d8a13a;
    --meh:#c98a3d;
    --left:#a8432f;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:'Zen Kaku Gothic New', sans-serif;
    padding-bottom:80px;
    -webkit-tap-highlight-color:transparent;
  }
  header{
    padding:28px 20px 18px;
    border-bottom:2px solid var(--line);
    background:var(--paper);
    position:sticky;
    top:0;
    z-index:10;
  }
  header h1{
    font-family:'Shippori Mincho', serif;
    font-weight:700;
    font-size:26px;
    margin:0;
    letter-spacing:.04em;
  }
  header .sub{
    font-size:12px;
    color:var(--muted);
    margin-top:4px;
    letter-spacing:.05em;
  }
  main{
    max-width:640px;
    margin:0 auto;
    padding:16px;
  }
  .tabbar{
    display:flex;
    gap:8px;
    margin-bottom:18px;
  }
  .tabbar button{
    flex:1;
    padding:10px 0;
    border:2px solid var(--line);
    background:var(--paper-card);
    color:var(--ink);
    font-family:'Zen Kaku Gothic New', sans-serif;
    font-weight:700;
    font-size:14px;
    border-radius:6px;
    cursor:pointer;
  }
  .tabbar button.active{
    background:var(--ink);
    color:var(--paper-card);
    border-color:var(--ink);
  }
  .panel{display:none;}
  .panel.active{display:block;}

  .card{
    background:var(--paper-card);
    border:1px solid var(--line);
    border-radius:8px;
    padding:16px;
    margin-bottom:14px;
    box-shadow:2px 2px 0 rgba(47,62,58,0.05);
  }
  .field{margin-bottom:14px;}
  .field label{
    display:block;
    font-size:12px;
    font-weight:700;
    color:var(--muted);
    margin-bottom:6px;
    letter-spacing:.03em;
  }
  input[type=date], input[type=text], textarea{
    width:100%;
    padding:9px 10px;
    border:1px solid var(--line);
    border-radius:5px;
    background:#fff;
    font-family:inherit;
    font-size:15px;
    color:var(--ink);
  }
  textarea{resize:vertical;min-height:50px;}

  .timepicker{display:flex;gap:8px;}
  .timepicker button{
    flex:1;
    padding:10px 0;
    border:2px solid var(--line);
    background:#fff;
    border-radius:6px;
    font-weight:700;
    font-size:14px;
    cursor:pointer;
    color:var(--muted);
  }
  .timepicker button[data-t="朝"].selected{background:var(--asa);border-color:var(--asa);color:#fff;}
  .timepicker button[data-t="昼"].selected{background:var(--hiru);border-color:var(--hiru);color:#fff;}
  .timepicker button[data-t="夜"].selected{background:var(--yoru);border-color:var(--yoru);color:#fff;}

  .menu-block{
    border:1px dashed var(--line);
    border-radius:8px;
    padding:12px;
    margin-bottom:12px;
    background:#fffdf8;
    position:relative;
  }
  .menu-block .remove-menu{
    position:absolute;
    top:8px;
    right:8px;
    border:none;
    background:none;
    color:var(--accent);
    font-size:18px;
    cursor:pointer;
    line-height:1;
  }
  .rating-row{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
    margin-top:4px;
  }
  .rating-row button{
    flex:1;
    min-width:70px;
    padding:7px 4px;
    font-size:12px;
    border-radius:5px;
    border:1px solid var(--line);
    background:#fff;
    color:var(--muted);
    cursor:pointer;
  }
  .rating-row button.selected[data-v="良く食べた"]{background:var(--good);color:#fff;border-color:var(--good);}
  .rating-row button.selected[data-v="食べた"]{background:var(--ok);color:#fff;border-color:var(--ok);}
  .rating-row button.selected[data-v="そこそこ"]{background:var(--meh);color:#fff;border-color:var(--meh);}
  .rating-row button.selected[data-v="残した"]{background:var(--left);color:#fff;border-color:var(--left);}

  .photo-preview{
    width:70px;height:70px;object-fit:cover;border-radius:6px;border:1px solid var(--line);display:block;margin-top:8px;
  }

  .btn{
    display:inline-block;
    padding:10px 18px;
    border-radius:6px;
    border:none;
    font-weight:700;
    font-size:14px;
    cursor:pointer;
    font-family:inherit;
  }
  .btn-primary{background:var(--accent);color:#fff;}
  .btn-secondary{background:#fff;border:1px solid var(--line);color:var(--ink);}
  .btn-block{width:100%;}
  .btn-ghost{background:none;border:1px dashed var(--line);color:var(--muted);width:100%;padding:12px;}

  .day-card{
    border:1px solid var(--line);
    border-radius:8px;
    margin-bottom:16px;
    overflow:hidden;
    background:var(--paper-card);
  }
  .day-head{
    padding:10px 14px;
    font-family:'Shippori Mincho', serif;
    font-weight:700;
    font-size:16px;
    background:var(--ink);
    color:var(--paper-card);
    display:flex;
    justify-content:space-between;
  }
  .meal-section{border-top:1px solid var(--line);padding:10px 14px;}
  .meal-label{
    font-size:11px;
    font-weight:700;
    padding:2px 8px;
    border-radius:3px;
    display:inline-block;
    color:#fff;
    margin-bottom:8px;
  }
  .meal-label.朝{background:var(--asa);}
  .meal-label.昼{background:var(--hiru);}
  .meal-label.夜{background:var(--yoru);}
  .menu-item{
    display:flex;
    gap:10px;
    padding:8px 0;
    border-bottom:1px solid #ece2c9;
  }
  .menu-item:last-child{border-bottom:none;}
  .menu-item img{width:52px;height:52px;object-fit:cover;border-radius:5px;flex-shrink:0;}
  .menu-item .noimg{width:52px;height:52px;border-radius:5px;flex-shrink:0;background:#ece2c9;}
  .menu-item .info{flex:1;min-width:0;}
  .menu-item .name{font-weight:700;font-size:14px;}
  .menu-item .ratings{font-size:12px;color:var(--muted);margin-top:2px;}
  .menu-item .memo{font-size:12px;color:var(--muted);margin-top:2px;font-style:italic;}
  .item-actions{display:flex;gap:6px;align-items:flex-start;}
  .item-actions button{
    border:none;background:none;color:var(--muted);font-size:14px;cursor:pointer;padding:2px 4px;
  }

  .empty{
    text-align:center;
    color:var(--muted);
    padding:40px 20px;
    font-size:14px;
  }

  .export-result{
    margin-top:14px;
    white-space:pre-wrap;
    font-size:13px;
    line-height:1.6;
    background:#fffdf8;
    border:1px solid var(--line);
    border-radius:6px;
    padding:12px;
    max-height:400px;
    overflow-y:auto;
  }
  .daterange{display:flex;gap:10px;}
  .daterange .field{flex:1;}

  .fab-row{display:flex;gap:10px;margin-top:6px;}
</style>
</head>
<body>

<header>
  <h1>献立ノート</h1>
  <div class="sub">今日の食卓を、あとで振り返るために</div>
</header>

<main>
  <div class="tabbar">
    <button class="tab-btn active" data-panel="add">記録する</button>
    <button class="tab-btn" data-panel="list">一覧</button>
    <button class="tab-btn" data-panel="export">出力</button>
  </div>

  <!-- 記録パネル -->
  <section class="panel active" id="panel-add">
    <div class="card">
      <div class="field">
        <label>登録日</label>
        <input type="date" id="entry-date">
      </div>
      <div class="field">
        <label>朝・昼・夜</label>
        <div class="timepicker" id="time-picker">
          <button type="button" data-t="朝">朝</button>
          <button type="button" data-t="昼">昼</button>
          <button type="button" data-t="夜">夜</button>
        </div>
      </div>
      <div id="menu-list"></div>
      <button type="button" class="btn-ghost" id="add-menu-btn">＋ メニューを追加</button>
    </div>
    <button type="button" class="btn btn-primary btn-block" id="save-entry-btn">この内容を保存</button>
    <div id="save-msg" style="text-align:center;font-size:13px;color:var(--muted);margin-top:8px;"></div>
  </section>

  <!-- 一覧パネル -->
  <section class="panel" id="panel-list">
    <div id="list-container"><div class="empty">まだ記録がありません</div></div>
  </section>

  <!-- 出力パネル -->
  <section class="panel" id="panel-export">
    <div class="card">
      <div class="daterange">
        <div class="field">
          <label>開始日</label>
          <input type="date" id="export-start">
        </div>
        <div class="field">
          <label>終了日</label>
          <input type="date" id="export-end">
        </div>
      </div>
      <button type="button" class="btn btn-primary btn-block" id="export-btn">テキスト出力</button>
    </div>
    <div id="export-actions" style="display:none;">
      <div class="fab-row">
        <button type="button" class="btn btn-secondary" id="copy-btn" style="flex:1;">コピー</button>
        <button type="button" class="btn btn-secondary" id="download-btn" style="flex:1;">.txtダウンロード</button>
      </div>
      <div class="export-result" id="export-result"></div>
    </div>
  </section>
</main>

<script>
/* ---------- IndexedDB ---------- */
const DB_NAME = 'gohan-tracker';
const DB_VERSION = 1;
const STORE = 'entries';
let db;

function openDB(){
  return new Promise((resolve, reject)=>{
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = (e)=>{
      const _db = e.target.result;
      if(!_db.objectStoreNames.contains(STORE)){
        const store = _db.createObjectStore(STORE, {keyPath:'id', autoIncrement:true});
        store.createIndex('date', 'date', {unique:false});
      }
    };
    req.onsuccess = (e)=>{ db = e.target.result; resolve(db); };
    req.onerror = (e)=> reject(e);
  });
}

function addEntry(entry){
  return new Promise((resolve, reject)=>{
    const tx = db.transaction(STORE, 'readwrite');
    const store = tx.objectStore(STORE);
    const req = store.add(entry);
    req.onsuccess = ()=> resolve(req.result);
    req.onerror = (e)=> reject(e);
  });
}

function updateEntry(entry){
  return new Promise((resolve, reject)=>{
    const tx = db.transaction(STORE, 'readwrite');
    const store = tx.objectStore(STORE);
    const req = store.put(entry);
    req.onsuccess = ()=> resolve(req.result);
    req.onerror = (e)=> reject(e);
  });
}

function deleteEntry(id){
  return new Promise((resolve, reject)=>{
    const tx = db.transaction(STORE, 'readwrite');
    const store = tx.objectStore(STORE);
    const req = store.delete(id);
    req.onsuccess = ()=> resolve();
    req.onerror = (e)=> reject(e);
  });
}

function getAllEntries(){
  return new Promise((resolve, reject)=>{
    const tx = db.transaction(STORE, 'readonly');
    const store = tx.objectStore(STORE);
    const req = store.getAll();
    req.onsuccess = ()=> resolve(req.result);
    req.onerror = (e)=> reject(e);
  });
}

/* ---------- 状態 ---------- */
let selectedTime = null;
let menuBlocks = []; // {id, name, photoData, ratingHusband, ratingYu, memo}
let menuBlockSeq = 0;
let editingId = null; // 編集中のエントリーID (null なら新規)

const todayStr = ()=> new Date().toISOString().slice(0,10);

/* ---------- タブ切替 ---------- */
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-'+btn.dataset.panel).classList.add('active');
    if(btn.dataset.panel==='list') renderList();
  });
});

/* ---------- 朝昼夜選択 ---------- */
document.getElementById('time-picker').addEventListener('click', (e)=>{
  const btn = e.target.closest('button');
  if(!btn) return;
  selectedTime = btn.dataset.t;
  document.querySelectorAll('#time-picker button').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
});

/* ---------- メニューブロック ---------- */
function createMenuBlock(data){
  const id = 'm'+(menuBlockSeq++);
  const block = {
    id,
    name: data?.name || '',
    photoData: data?.photoData || null,
    ratingHusband: data?.ratingHusband || null,
    ratingYu: data?.ratingYu || null,
    memo: data?.memo || ''
  };
  menuBlocks.push(block);
  renderMenuBlocks();
}

function renderMenuBlocks(){
  const container = document.getElementById('menu-list');
  container.innerHTML = '';
  menuBlocks.forEach(block=>{
    const div = document.createElement('div');
    div.className = 'menu-block';
    div.dataset.id = block.id;
    div.innerHTML = `
      <button type="button" class="remove-menu" data-action="remove">×</button>
      <div class="field">
        <label>メニュー名</label>
        <input type="text" class="menu-name" placeholder="例：肉じゃが" value="${escapeHtml(block.name)}">
      </div>
      <div class="field">
        <label>写真（任意・1枚）</label>
        <input type="file" accept="image/*" class="menu-photo">
        ${block.photoData ? `<img src="${block.photoData}" class="photo-preview">` : ''}
      </div>
      <div class="field">
        <label>夫の評価</label>
        <div class="rating-row" data-who="husband">
          ${['良く食べた','食べた','そこそこ','残した'].map(v=>`<button type="button" data-v="${v}" class="${block.ratingHusband===v?'selected':''}">${v}</button>`).join('')}
        </div>
      </div>
      <div class="field">
        <label>ゆうちゃんの評価</label>
        <div class="rating-row" data-who="yu">
          ${['良く食べた','食べた','そこそこ','残した'].map(v=>`<button type="button" data-v="${v}" class="${block.ratingYu===v?'selected':''}">${v}</button>`).join('')}
        </div>
      </div>
      <div class="field">
        <label>メモ</label>
        <textarea class="menu-memo" placeholder="自由に">${escapeHtml(block.memo)}</textarea>
      </div>
    `;
    container.appendChild(div);

    div.querySelector('[data-action="remove"]').addEventListener('click', ()=>{
      menuBlocks = menuBlocks.filter(b=>b.id!==block.id);
      renderMenuBlocks();
    });
    div.querySelector('.menu-name').addEventListener('input', (e)=> block.name = e.target.value);
    div.querySelector('.menu-memo').addEventListener('input', (e)=> block.memo = e.target.value);
    div.querySelector('.menu-photo').addEventListener('change', (e)=>{
      const file = e.target.files[0];
      if(!file) return;
      const reader = new FileReader();
      reader.onload = ()=>{
        block.photoData = reader.result;
        renderMenuBlocks();
      };
      reader.readAsDataURL(file);
    });
    div.querySelectorAll('.rating-row').forEach(row=>{
      row.addEventListener('click', (e)=>{
        const btn = e.target.closest('button');
        if(!btn) return;
        const who = row.dataset.who;
        if(who==='husband') block.ratingHusband = btn.dataset.v;
        else block.ratingYu = btn.dataset.v;
        renderMenuBlocks();
      });
    });
  });
}

function escapeHtml(str){
  const d = document.createElement('div');
  d.textContent = str || '';
  return d.innerHTML;
}

document.getElementById('add-menu-btn').addEventListener('click', ()=> createMenuBlock());

/* ---------- 保存 ---------- */
function resetForm(){
  document.getElementById('entry-date').value = todayStr();
  selectedTime = null;
  document.querySelectorAll('#time-picker button').forEach(b=>b.classList.remove('selected'));
  menuBlocks = [];
  editingId = null;
  renderMenuBlocks();
  createMenuBlock();
}

document.getElementById('save-entry-btn').addEventListener('click', async ()=>{
  const msgEl = document.getElementById('save-msg');
  const date = document.getElementById('entry-date').value;
  if(!date){ msgEl.textContent = '登録日を入力してください'; return; }
  if(!selectedTime){ msgEl.textContent = '朝・昼・夜を選択してください'; return; }
  const validMenus = menuBlocks.filter(b=>b.name.trim()!=='');
  if(validMenus.length===0){ msgEl.textContent = 'メニュー名を1つ以上入力してください'; return; }

  const entry = {
    date,
    time: selectedTime,
    menus: validMenus.map(b=>({
      name: b.name.trim(),
      photoData: b.photoData,
      ratingHusband: b.ratingHusband,
      ratingYu: b.ratingYu,
      memo: b.memo.trim()
    }))
  };

  try{
    if(editingId){
      entry.id = editingId;
      await updateEntry(entry);
      msgEl.textContent = '更新しました';
    } else {
      await addEntry(entry);
      msgEl.textContent = '保存しました';
    }
    setTimeout(()=>{ msgEl.textContent=''; }, 2000);
    resetForm();
  }catch(err){
    console.error(err);
    msgEl.textContent = '保存に失敗しました';
  }
});

/* ---------- 一覧表示 ---------- */
async function renderList(){
  const container = document.getElementById('list-container');
  const entries = await getAllEntries();
  if(entries.length===0){
    container.innerHTML = '<div class="empty">まだ記録がありません</div>';
    return;
  }
  // 日付ごとにグループ化、日付降順
  const byDate = {};
  entries.forEach(e=>{
    if(!byDate[e.date]) byDate[e.date] = [];
    byDate[e.date].push(e);
  });
  const dates = Object.keys(byDate).sort((a,b)=> b.localeCompare(a));
  const timeOrder = {'朝':0,'昼':1,'夜':2};

  container.innerHTML = '';
  dates.forEach(date=>{
    const dayEntries = byDate[date].sort((a,b)=> timeOrder[a.time]-timeOrder[b.time]);
    const dayCard = document.createElement('div');
    dayCard.className = 'day-card';
    const dObj = new Date(date+'T00:00:00');
    const weekday = ['日','月','火','水','木','金','土'][dObj.getDay()];
    dayCard.innerHTML = `<div class="day-head"><span>${date}（${weekday}）</span></div>`;

    dayEntries.forEach(entry=>{
      const section = document.createElement('div');
      section.className = 'meal-section';
      let itemsHtml = '';
      entry.menus.forEach((m, idx)=>{
        itemsHtml += `
          <div class="menu-item">
            ${m.photoData ? `<img src="${m.photoData}">` : `<div class="noimg"></div>`}
            <div class="info">
              <div class="name">${escapeHtml(m.name)}</div>
              <div class="ratings">夫：${m.ratingHusband||'未評価'} ／ ゆうちゃん：${m.ratingYu||'未評価'}</div>
              ${m.memo ? `<div class="memo">${escapeHtml(m.memo)}</div>` : ''}
            </div>
          </div>
        `;
      });
      section.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span class="meal-label ${entry.time}">${entry.time}</span>
          <div class="item-actions">
            <button data-action="edit" data-id="${entry.id}">編集</button>
            <button data-action="delete" data-id="${entry.id}">削除</button>
          </div>
        </div>
        ${itemsHtml}
      `;
      dayCard.appendChild(section);
    });
    container.appendChild(dayCard);
  });

  container.querySelectorAll('[data-action="edit"]').forEach(btn=>{
    btn.addEventListener('click', async ()=>{
      const id = Number(btn.dataset.id);
      const entries = await getAllEntries();
      const entry = entries.find(e=>e.id===id);
      if(!entry) return;
      editingId = id;
      document.getElementById('entry-date').value = entry.date;
      selectedTime = entry.time;
      document.querySelectorAll('#time-picker button').forEach(b=>{
        b.classList.toggle('selected', b.dataset.t===entry.time);
      });
      menuBlocks = [];
      renderMenuBlocks();
      entry.menus.forEach(m=> createMenuBlock({
        name:m.name, photoData:m.photoData, ratingHusband:m.ratingHusband, ratingYu:m.ratingYu, memo:m.memo
      }));
      document.querySelector('.tab-btn[data-panel="add"]').click();
    });
  });
  container.querySelectorAll('[data-action="delete"]').forEach(btn=>{
    btn.addEventListener('click', async ()=>{
      if(!confirm('この記録を削除しますか？')) return;
      await deleteEntry(Number(btn.dataset.id));
      renderList();
    });
  });
}

/* ---------- テキスト出力 ---------- */
document.getElementById('export-btn').addEventListener('click', async ()=>{
  const start = document.getElementById('export-start').value;
  const end = document.getElementById('export-end').value;
  if(!start || !end){ alert('開始日と終了日を指定してください'); return; }

  const entries = await getAllEntries();
  const filtered = entries.filter(e=> e.date>=start && e.date<=end);

  const byDate = {};
  filtered.forEach(e=>{
    if(!byDate[e.date]) byDate[e.date] = [];
    byDate[e.date].push(e);
  });
  const dates = Object.keys(byDate).sort();
  const timeOrder = {'朝':0,'昼':1,'夜':2};

  let text = '';
  if(dates.length===0){
    text = '（該当期間の記録はありません）';
  } else {
    dates.forEach(date=>{
      const dObj = new Date(date+'T00:00:00');
      const weekday = ['日','月','火','水','木','金','土'][dObj.getDay()];
      text += `■${date}（${weekday}）\n`;
      const dayEntries = byDate[date].sort((a,b)=> timeOrder[a.time]-timeOrder[b.time]);
      ['朝','昼','夜'].forEach(t=>{
        const e = dayEntries.find(x=>x.time===t);
        text += `【${t}】\n`;
        if(!e || e.menus.length===0){
          text += '（記録なし）\n';
        } else {
          e.menus.forEach(m=>{
            text += `・${m.name}（夫：${m.ratingHusband||'未評価'}／ゆうちゃん：${m.ratingYu||'未評価'}）`;
            if(m.memo) text += ` メモ：${m.memo}`;
            text += '\n';
          });
        }
      });
      text += '\n';
    });
  }

  document.getElementById('export-result').textContent = text;
  document.getElementById('export-actions').style.display = 'block';
  window._exportText = text;
});

document.getElementById('copy-btn').addEventListener('click', async ()=>{
  try{
    await navigator.clipboard.writeText(window._exportText || '');
    const btn = document.getElementById('copy-btn');
    const orig = btn.textContent;
    btn.textContent = 'コピーしました';
    setTimeout(()=> btn.textContent = orig, 1500);
  }catch(err){
    alert('コピーに失敗しました。手動で選択してコピーしてください。');
  }
});

document.getElementById('download-btn').addEventListener('click', ()=>{
  const start = document.getElementById('export-start').value;
  const end = document.getElementById('export-end').value;
  const blob = new Blob([window._exportText || ''], {type:'text/plain'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `献立記録_${start}_${end}.txt`;
  a.click();
  URL.revokeObjectURL(url);
});

/* ---------- 初期化 ---------- */
(async function init(){
  await openDB();
  document.getElementById('entry-date').value = todayStr();
  const today = todayStr();
  document.getElementById('export-start').value = today;
  document.getElementById('export-end').value = today;
  createMenuBlock();
})();
</script>
</body>
